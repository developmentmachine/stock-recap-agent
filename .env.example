# ─── LLM 后端 ─────────────────────────────────────────────────────────────────
# 强制指定后端：openai / ollama / cursor-cli / gemini-cli
# 也可通过 RECAP_MODEL 前缀指定，例如 ollama:qwen2.5、gemini:gemini-2.0-flash
RECAP_LLM_BACKEND=

# OpenAI
OPENAI_API_KEY=

# Gemini CLI（本地 gemini-cli 工具）
GEMINI_API_KEY=
RECAP_GEMINI_CLI_CMD=gemini

# Cursor CLI（终端命令名为 agent，产品名 cursor-cli；文档 https://cursor.com/zh-Hant/docs/cli/overview ）
RECAP_CURSOR_CLI_CMD=agent
# 兼容旧变量名（等价于 RECAP_CURSOR_CLI_CMD）
# RECAP_CURSOR_AGENT_CMD=agent

# Ollama（本地服务）
RECAP_OLLAMA_BASE_URL=http://127.0.0.1:11434

# 模型名（当后端为 openai 时生效）
RECAP_MODEL=gpt-4.1-mini

# ─── 数据库 ───────────────────────────────────────────────────────────────────
# 生产推荐使用文件持久化（WAL 模式、跨进程安全）。
# 将路径设为 :memory: 仅适合单进程测试——多线程/多 worker 下共享内存连接
# 会引发竞争条件，历史记录与进化笔记也会在进程退出时丢失。
RECAP_DB_PATH=recap_system.db

# ─── API 安全 ─────────────────────────────────────────────────────────────────
# 设置后，所有 /v1/* 接口需要 X-API-Key 请求头
RECAP_API_KEY=

# 浏览器跨域（逗号分隔 Origin）；留空则不启用 CORS
# RECAP_CORS_ORIGINS=http://localhost:5173,https://your-frontend.example

# ─── 推送 ─────────────────────────────────────────────────────────────────────
RECAP_PUSH_ENABLED=false
RECAP_WXWORK_WEBHOOK_URL=

# ─── 调度 ─────────────────────────────────────────────────────────────────────
RECAP_SCHEDULER_ENABLED=false
RECAP_SCHEDULER_DAILY_HOUR=15
RECAP_SCHEDULER_DAILY_MINUTE=30

# ─── MCP 工具 ─────────────────────────────────────────────────────────────────
# 总开关：true 启用工具调用（OpenAI/Ollama 用 function calling，cursor/gemini 用预执行注入）
RECAP_TOOLS_ENABLED=false
RECAP_TOOLS_WEB_SEARCH=true
RECAP_TOOLS_MARKET_DATA=true
RECAP_TOOLS_HISTORY=true

# ─── Skills（manifest + SKILL.md）────────────────────────────────────────────
# 覆盖 mode→skill 映射（单 skill id）
# RECAP_SKILL_ID=my.custom.skill
# 逗号分隔的额外 bundle 根目录（各含 manifest.json）；与内置合并，后写覆盖同 id
# RECAP_SKILL_EXTRA_DIRS=/path/to/my-skills,/path/to/team-skills
# 第三方 wheel 也可用 pyproject [project.entry-points."agent_platform.skills"] 指向 bundle 根

RECAP_LOG_LEVEL=INFO
